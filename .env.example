# Application environment
MERIDIAN_APP_ENV=development

# Production/Shared-Dev Database (Neon Postgres)
# Used for operational data: shipments, quotes, booking confirmations
MERIDIAN_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/meridian_logistics
MERIDIAN_DIRECT_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/meridian_logistics

# Session/Job State Database (local fallback: SQLite)
# Used for session state and async job tracking
# Production: Use same Neon Postgres as MERIDIAN_DATABASE_URL
# Local: Omit this to use SQLite at .runtime/meridian_state.sqlite3
# MERIDIAN_STATE_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/meridian_logistics

# Redis (optional, for future use)
MERIDIAN_REDIS_URL=redis://localhost:6379/0

# Contracts directory
MERIDIAN_CONTRACTS_DIR=contracts

# Backblaze B2 for generated artifacts (PDFs, exports, replay bundles)
MERIDIAN_OBJECT_STORAGE_PROVIDER=backblaze_b2
MERIDIAN_OBJECT_STORAGE_PREFIX=artifacts/dev
MERIDIAN_B2_PREFIX=artifacts/dev
MERIDIAN_B2_ENDPOINT=
MERIDIAN_B2_BUCKET_NAME=
MERIDIAN_B2_ACCESS_KEY_ID=
MERIDIAN_B2_SECRET_ACCESS_KEY=

# Office configuration
MERIDIAN_MEMPHIS_OFFICE_ID=memphis
