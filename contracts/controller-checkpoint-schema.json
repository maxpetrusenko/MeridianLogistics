{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "contract_name": "controller_checkpoint",
  "contract_version": "0.1.0",
  "status": "draft_ready_for_review",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "checkpoint_id",
    "checkpoint_version",
    "created_at",
    "protected_core",
    "compaction",
    "validated_artifacts",
    "active_failure_signal",
    "controller_last_decision",
    "queue",
    "terminal_state"
  ],
  "properties": {
    "checkpoint_id": {
      "type": "string",
      "minLength": 1
    },
    "checkpoint_version": {
      "type": "string",
      "const": "0.1.0"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "protected_core": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "task_goal",
        "expected_output",
        "current_step",
        "resume_point",
        "hard_constraints",
        "business_invariants"
      ],
      "properties": {
        "task_goal": {
          "type": "string",
          "minLength": 1
        },
        "expected_output": {
          "type": "string",
          "minLength": 1
        },
        "current_step": {
          "type": "string",
          "minLength": 1
        },
        "resume_point": {
          "type": "string",
          "minLength": 1
        },
        "hard_constraints": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "business_invariants": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "compaction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "strategy_name",
        "compaction_sequence",
        "halo_summary",
        "recent_turn_ids",
        "drift_status"
      ],
      "properties": {
        "strategy_name": {
          "type": "string",
          "minLength": 1
        },
        "compaction_sequence": {
          "type": "integer",
          "minimum": 0
        },
        "halo_summary": {
          "type": "string"
        },
        "recent_turn_ids": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 0
          }
        },
        "drift_status": {
          "type": "string",
          "enum": ["stable", "watch", "drift_detected"]
        }
      }
    },
    "validated_artifacts": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "active_failure_signal": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "severity", "source", "details"],
      "properties": {
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "severity": {
          "type": "string",
          "enum": ["none", "recoverable", "unsafe"]
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "details": {
          "type": ["string", "null"]
        }
      }
    },
    "controller_last_decision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action", "reason", "source"],
      "properties": {
        "action": {
          "type": "string",
          "enum": ["continue", "review", "repair", "abort"]
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "source": {
          "type": "string",
          "enum": ["controller", "review", "triage", "validator"]
        }
      }
    },
    "queue": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": [
        "wave_name",
        "status",
        "run_policy",
        "eligible",
        "requires_explicit_request"
      ],
      "properties": {
        "wave_name": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": ["queued", "active", "done", "blocked"]
        },
        "run_policy": {
          "type": "string",
          "enum": ["auto", "explicit_request", "blocked_until_input"]
        },
        "eligible": {
          "type": "boolean"
        },
        "requires_explicit_request": {
          "type": "boolean"
        },
        "approval_authority": {
          "type": "string",
          "enum": ["main", "user"]
        }
      }
    },
    "terminal_state": {
      "type": ["string", "null"],
      "enum": ["DONE", "BLOCKED", "WAITING_APPROVAL", "WAITING_USER_APPROVAL", "ABORTED", null]
    }
  }
}
