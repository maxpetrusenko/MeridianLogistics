{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "contract_name": "agent_response",
  "contract_version": "0.1.0",
  "status": "draft_ready_for_review",
  "authoritative_inputs": [
    "prd.md",
    "architecture-overview.md",
    "backlog.md",
    "decisions.md"
  ],
  "description": "Structured response envelope for Memphis PoC read answers, denials, and booking confirmation flows.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "response_id",
    "request_id",
    "intent_class",
    "status",
    "summary",
    "components",
    "policy",
    "audit"
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "intent_class": {
            "const": "read_pending"
          }
        },
        "required": [
          "intent_class"
        ]
      },
      "then": {
        "required": [
          "job_id",
          "job_poll_token"
        ],
        "properties": {
          "job_id": {
            "type": "string",
            "pattern": "^job_[A-Za-z0-9_]+$"
          },
          "job_poll_token": {
            "type": "string",
            "minLength": 16
          },
          "status": {
            "const": "pending"
          },
          "actions": {
            "maxItems": 0
          },
          "audit": {
            "type": "object",
            "properties": {
              "tool_path": {
                "minItems": 0
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "intent_class": {
            "const": "read_result"
          }
        },
        "required": [
          "intent_class"
        ]
      },
      "then": {
        "properties": {
          "status": {
            "const": "success"
          },
          "audit": {
            "type": "object",
            "properties": {
              "tool_path": {
                "minItems": 1
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "intent_class": {
            "const": "read_denied"
          }
        },
        "required": [
          "intent_class"
        ]
      },
      "then": {
        "properties": {
          "status": {
            "const": "denied"
          },
          "actions": {
            "maxItems": 0
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "intent_class": {
            "const": "write_confirmation_required"
          }
        },
        "required": [
          "intent_class"
        ]
      },
      "then": {
        "required": [
          "actions"
        ],
        "properties": {
          "status": {
            "const": "confirmation_required"
          },
          "components": {
            "contains": {
              "$ref": "#/$defs/confirmation_card_component"
            }
          },
          "actions": {
            "allOf": [
              {
                "contains": {
                  "type": "object",
                  "required": [
                    "action_type"
                  ],
                  "properties": {
                    "action_type": {
                      "const": "confirm_booking"
                    }
                  }
                }
              },
              {
                "contains": {
                  "type": "object",
                  "required": [
                    "action_type"
                  ],
                  "properties": {
                    "action_type": {
                      "const": "cancel_booking"
                    }
                  }
                }
              }
            ]
          },
          "policy": {
            "type": "object",
            "required": [
              "write_confirmation_required"
            ],
            "properties": {
              "write_confirmation_required": {
                "const": true
              }
            }
          },
          "audit": {
            "type": "object",
            "properties": {
              "tool_path": {
                "minItems": 1
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "intent_class": {
            "const": "write_submitted"
          }
        },
        "required": [
          "intent_class"
        ]
      },
      "then": {
        "properties": {
          "status": {
            "const": "submitted"
          },
          "actions": {
            "maxItems": 0
          },
          "audit": {
            "type": "object",
            "properties": {
              "tool_path": {
                "minItems": 1
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "intent_class": {
            "const": "write_denied"
          }
        },
        "required": [
          "intent_class"
        ]
      },
      "then": {
        "properties": {
          "status": {
            "const": "denied"
          },
          "actions": {
            "maxItems": 0
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "intent_class": {
            "const": "error"
          }
        },
        "required": [
          "intent_class"
        ]
      },
      "then": {
        "properties": {
          "status": {
            "const": "error"
          },
          "actions": {
            "maxItems": 0
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "intent_class": {
            "not": {
              "const": "write_confirmation_required"
            }
          }
        },
        "required": [
          "intent_class"
        ]
      },
      "then": {
        "properties": {
          "components": {
            "not": {
              "contains": {
                "$ref": "#/$defs/confirmation_card_component"
              }
            }
          },
          "actions": {
            "items": {
              "allOf": [
                {
                  "$ref": "#/$defs/action_button"
                },
                {
                  "type": "object",
                  "required": [
                    "action_type"
                  ],
                  "properties": {
                    "action_type": {
                      "enum": [
                        "open_details",
                        "request_refinement"
                      ]
                    }
                  }
                }
              ]
            }
          },
          "policy": {
            "type": "object",
            "required": [
              "write_confirmation_required"
            ],
            "properties": {
              "write_confirmation_required": {
                "const": false
              }
            }
          }
        }
      }
    }
  ],
  "properties": {
    "contract_version": {
      "type": "string",
      "const": "0.1.0"
    },
    "response_id": {
      "type": "string",
      "minLength": 1
    },
    "request_id": {
      "type": "string",
      "minLength": 1
    },
    "trace_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "intent_class": {
      "type": "string",
      "enum": [
        "read_pending",
        "read_result",
        "read_denied",
        "write_confirmation_required",
        "write_submitted",
        "write_denied",
        "error"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "success",
        "denied",
        "confirmation_required",
        "submitted",
        "error"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "follow_up_prompt": {
      "type": [
        "string",
        "null"
      ]
    },
    "components": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          {
            "$ref": "#/$defs/message_block_component"
          },
          {
            "$ref": "#/$defs/table_component"
          },
          {
            "$ref": "#/$defs/metric_card_component"
          },
          {
            "$ref": "#/$defs/timeline_component"
          },
          {
            "$ref": "#/$defs/confirmation_card_component"
          }
        ]
      }
    },
    "actions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/action_button"
      },
      "default": []
    },
    "session_id": {
      "type": "string",
      "pattern": "^chat_s_[A-Za-z0-9_]+$"
    },
    "session_access_token": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 16
    },
    "conversation_scope": {
      "type": "string",
      "enum": [
        "global",
        "office",
        "shipment",
        "lane",
        "carrier",
        "analytics"
      ]
    },
    "context_binding_state": {
      "type": "string",
      "enum": [
        "bound",
        "partial",
        "stale",
        "missing"
      ]
    },
    "screen_sync_state": {
      "type": "string",
      "enum": [
        "not_applicable",
        "pending",
        "applied",
        "blocked"
      ]
    },
    "active_resource": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": false,
      "required": [
        "resource_type",
        "resource_id",
        "resource_fingerprint"
      ],
      "properties": {
        "resource_type": {
          "type": "string",
          "enum": [
            "shipment",
            "carrier",
            "lane",
            "analytics",
            "session"
          ]
        },
        "resource_id": {
          "type": "string",
          "minLength": 1
        },
        "resource_fingerprint": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "job_id": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^job_[A-Za-z0-9_]+$"
    },
    "job_poll_token": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 16
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "permission_context_applied",
        "sensitive_fields_redacted",
        "write_confirmation_required"
      ],
      "properties": {
        "permission_context_applied": {
          "type": "boolean",
          "const": true
        },
        "sensitive_fields_redacted": {
          "type": "boolean",
          "const": true
        },
        "write_confirmation_required": {
          "type": "boolean"
        },
        "denial_reason_class": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "permission",
            "sensitive_field",
            "unsupported_request",
            "stale_state",
            "query_safety",
            "none",
            null
          ]
        }
      }
    },
    "audit": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "actor_role",
        "office_scope",
        "tool_path",
        "response_generated_at"
      ],
      "properties": {
        "actor_role": {
          "type": "string",
          "enum": [
            "broker"
          ]
        },
        "office_scope": {
          "type": "string",
          "minLength": 1
        },
        "tool_path": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "response_generated_at": {
          "type": "string",
          "format": "date-time"
        },
        "autonomy_mode": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "poll_driven"
          ]
        },
        "autonomy_task_kind": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "async_read_refresh"
          ]
        },
        "autonomy_run_id": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "checkpoint_id": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        }
      }
    }
  },
  "$defs": {
    "component_base": {
      "type": "object",
      "required": [
        "component_id",
        "component_type"
      ],
      "properties": {
        "component_id": {
          "type": "string",
          "minLength": 1
        },
        "component_type": {
          "type": "string"
        },
        "title": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "message_block_component": {
      "unevaluatedProperties": false,
      "allOf": [
        {
          "$ref": "#/$defs/component_base"
        },
        {
          "type": "object",
          "required": [
            "component_type",
            "body"
          ],
          "properties": {
            "component_type": {
              "const": "message_block"
            },
            "body": {
              "type": "string",
              "minLength": 1
            },
            "tone": {
              "type": "string",
              "enum": [
                "informational",
                "warning",
                "error"
              ]
            }
          }
        }
      ]
    },
    "table_component": {
      "unevaluatedProperties": false,
      "allOf": [
        {
          "$ref": "#/$defs/component_base"
        },
        {
          "type": "object",
          "required": [
            "component_type",
            "columns",
            "rows"
          ],
          "properties": {
            "component_type": {
              "const": "table"
            },
            "columns": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "key",
                  "label",
                  "data_type"
                ],
                "properties": {
                  "key": {
                    "type": "string"
                  },
                  "label": {
                    "type": "string"
                  },
                  "data_type": {
                    "type": "string",
                    "enum": [
                      "string",
                      "number",
                      "date",
                      "datetime",
                      "status"
                    ]
                  }
                }
              }
            },
            "rows": {
              "type": "array",
              "items": {
                "type": "array",
                "items": {
                  "type": [
                    "string",
                    "number",
                    "boolean",
                    "null"
                  ]
                }
              }
            }
          }
        }
      ]
    },
    "metric_card_component": {
      "unevaluatedProperties": false,
      "allOf": [
        {
          "$ref": "#/$defs/component_base"
        },
        {
          "type": "object",
          "required": [
            "component_type",
            "metrics"
          ],
          "properties": {
            "component_type": {
              "const": "metric_card"
            },
            "metrics": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "label",
                  "value"
                ],
                "properties": {
                  "label": {
                    "type": "string"
                  },
                  "value": {
                    "type": [
                      "string",
                      "number"
                    ]
                  },
                  "unit": {
                    "type": [
                      "string",
                      "null"
                    ]
                  }
                }
              }
            }
          }
        }
      ]
    },
    "timeline_component": {
      "unevaluatedProperties": false,
      "allOf": [
        {
          "$ref": "#/$defs/component_base"
        },
        {
          "type": "object",
          "required": [
            "component_type",
            "events"
          ],
          "properties": {
            "component_type": {
              "const": "timeline"
            },
            "events": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "label",
                  "timestamp"
                ],
                "properties": {
                  "label": {
                    "type": "string"
                  },
                  "timestamp": {
                    "type": "string"
                  },
                  "state": {
                    "type": [
                      "string",
                      "null"
                    ]
                  }
                }
              }
            }
          }
        }
      ]
    },
    "confirmation_card_component": {
      "unevaluatedProperties": false,
      "allOf": [
        {
          "$ref": "#/$defs/component_base"
        },
        {
          "type": "object",
          "required": [
            "component_type",
            "action_name",
            "confirmation_token",
            "expires_at",
            "fields"
          ],
          "properties": {
            "component_type": {
              "const": "confirmation_card"
            },
            "action_name": {
              "type": "string",
              "const": "booking_create_confirmed"
            },
            "confirmation_token": {
              "type": "string",
              "minLength": 1
            },
            "expires_at": {
              "type": "string",
              "format": "date-time"
            },
            "fields": {
              "type": "array",
              "minItems": 3,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "key",
                  "label",
                  "value"
                ],
                "properties": {
                  "key": {
                    "type": "string"
                  },
                  "label": {
                    "type": "string"
                  },
                  "value": {
                    "type": [
                      "string",
                      "number"
                    ]
                  }
                }
              }
            }
          }
        }
      ]
    },
    "action_button": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action_id",
        "label",
        "action_type",
        "resource_type",
        "resource_id",
        "surface",
        "requires_confirmation",
        "enabled",
        "disabled_reason"
      ],
      "properties": {
        "action_id": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "action_type": {
          "type": "string",
          "enum": [
            "open_details",
            "request_refinement",
            "confirm_booking",
            "cancel_booking"
          ]
        },
        "resource_type": {
          "type": "string",
          "enum": [
            "shipment",
            "carrier",
            "lane",
            "analytics",
            "session"
          ]
        },
        "resource_id": {
          "type": "string",
          "minLength": 1
        },
        "surface": {
          "type": "string",
          "enum": [
            "chat",
            "main_surface",
            "drawer",
            "modal"
          ]
        },
        "requires_confirmation": {
          "type": "boolean"
        },
        "enabled": {
          "type": "boolean"
        },
        "disabled_reason": {
          "type": [
            "string",
            "null"
          ]
        },
        "server_endpoint": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "method",
            "path"
          ],
          "properties": {
            "method": {
              "type": "string",
              "enum": [
                "GET",
                "POST",
                "PATCH",
                "DELETE"
              ]
            },
            "path": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "permission_scope": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "office_id",
            "role",
            "broker_id"
          ],
          "properties": {
            "office_id": {
              "type": "string",
              "minLength": 1
            },
            "role": {
              "type": "string",
              "enum": [
                "broker"
              ]
            },
            "broker_id": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "confirmation_token": {
          "type": "string",
          "minLength": 1
        },
        "confirmation_expires_at": {
          "type": "string",
          "format": "date-time"
        },
        "idempotency_key": {
          "type": "string",
          "minLength": 1
        },
        "ui_behavior": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "success_mode",
            "failure_mode",
            "post_success_refresh"
          ],
          "properties": {
            "success_mode": {
              "type": "string",
              "enum": [
                "chat_only",
                "sync_chat_and_screen"
              ]
            },
            "failure_mode": {
              "type": "string",
              "enum": [
                "stay_in_confirmation",
                "show_failure_message"
              ]
            },
            "post_success_refresh": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "minItems": 1
            }
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "action_type": {
                "const": "confirm_booking"
              }
            },
            "required": [
              "action_type"
            ]
          },
          "then": {
            "required": [
              "server_endpoint",
              "permission_scope",
              "confirmation_token",
              "confirmation_expires_at",
              "idempotency_key",
              "ui_behavior"
            ],
            "properties": {
              "requires_confirmation": {
                "const": true
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "action_type": {
                "const": "cancel_booking"
              }
            },
            "required": [
              "action_type"
            ]
          },
          "then": {
            "properties": {
              "requires_confirmation": {
                "const": false
              }
            }
          }
        }
      ]
    }
  }
}
